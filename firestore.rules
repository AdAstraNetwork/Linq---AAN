rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isStoreOwner(storeId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/stores/$(storeId)) &&
             get(/databases/$(database)/documents/stores/$(storeId)).data.ownerUid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "info@adastranetwork.co.uk" || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalStamps', 'totalRedeemed', 'total_cards_held']));
      allow delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdmin();
      allow update, delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || resource.data.ownerUid == "system_seed" || isAdmin());
      
      match /posts/{postId} {
        allow read: if true;
        allow create: if isAuthenticated() || isAdmin();
        allow update, delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isStoreOwner(storeId) || isAdmin());
      }
    }

    // Support collectionGroup queries for posts
    match /{path=**}/posts/{postId} {
      allow read: if true;
    }

    match /cards/{cardId} {
      // Allow authenticated users to read their own cards, or store owners to read cards for their store.
      // Allow reading non-archived cards for the leaderboard.
      allow read: if isAuthenticated() && (
        (resource == null) || 
        (request.auth.uid == resource.data.user_id) ||
        (isStoreOwner(resource.data.store_id)) ||
        (!('isArchived' in resource.data) || resource.data.isArchived == false) ||
        isAdmin()
      );
      allow create: if isAuthenticated() || isAdmin();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isStoreOwner(resource.data.store_id) || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isStoreOwner(resource.data.store_id) || isAdmin());
      allow create: if isAuthenticated() || isAdmin();
    }

    match /user_reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.fromUid == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || isAdmin());

      match /replies/{replyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.fromUid == request.auth.uid;
      }

      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.followerUid == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.followerUid == request.auth.uid || isAdmin());
    }

    match /global_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'likedBy']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollVotes']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['pollVotes', 'likesCount', 'likedBy']) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() || isAdmin();
      allow update, delete: if isAuthenticated() && (resource.data.toUid == request.auth.uid || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.uids || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.uids || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.uids || isAdmin());

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.uids || isAdmin());
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.uids || isAdmin());
      }
    }
  }
}
